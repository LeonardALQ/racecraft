---
import Layout from '../../layouts/Layout.astro';
import MathTiers from '../../components/MathTiers.astro';
---
<Layout>
  <main class="mx-auto max-w-3xl px-5">
    <div class="pt-10 pb-4">
      <a href="/samples" class="label hover:underline">&larr; Panel samples</a>
      <div class="part-kicker mt-4">Option A</div>
      <h1 class="part-title">Slide-in Drawer</h1>
      <p class="prose-manual max-w-2xl">
        The reading column stays full-width and uncluttered. A trigger opens a focused
        drawer over the right side; close it to return to reading. Good when the maths is
        an occasional deep-dive rather than a constant companion.
      </p>
    </div>

    <section class="py-6 border-t border-[var(--color-rule)]">
      <div class="label mb-2">Section 02</div>
      <h3 class="text-xl mb-4">The Traction Budget</h3>
      <div class="prose-manual max-w-2xl">
        <p>
          At the limit you get <strong>one</strong> of: 100% throttle, 100% brake, or 100%
          lean. They share a single budget of grip — brake at 70% and you can still lean at
          70%, because the demands add as a vector, not a sum.
        </p>
        <p class="mt-3">
          That's the intuition. The exact relationship — and how it bends once real tyres,
          load and camber enter — lives in the maths.
        </p>
        <button class="open-maths" data-open-drawer>&#8862; Open the maths</button>
      </div>
    </section>
  </main>

  <div class="drawer-backdrop" data-backdrop hidden></div>
  <aside class="drawer" data-drawer aria-hidden="true">
    <div class="drawer-head">
      <span class="label"><span class="section-num">&sum;</span>&nbsp;The Maths — Traction Budget</span>
      <button class="drawer-close" data-close-drawer aria-label="Close">&times;</button>
    </div>
    <div class="drawer-body">
      <MathTiers />
    </div>
  </aside>

  <script>
    const drawer = document.querySelector('[data-drawer]');
    const backdrop = document.querySelector('[data-backdrop]');
    const open = () => { drawer?.classList.add('open'); backdrop?.removeAttribute('hidden'); drawer?.setAttribute('aria-hidden','false'); };
    const close = () => { drawer?.classList.remove('open'); backdrop?.setAttribute('hidden',''); drawer?.setAttribute('aria-hidden','true'); };
    document.querySelectorAll('[data-open-drawer]').forEach((b) => b.addEventListener('click', open));
    document.querySelectorAll('[data-close-drawer]').forEach((b) => b.addEventListener('click', close));
    backdrop?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  </script>

  <style>
    .open-maths {
      font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.04em;
      border: 1px solid var(--color-ink); background: var(--color-ink); color: var(--color-paper);
      padding: 0.45rem 0.8rem; cursor: pointer; margin-top: 1rem;
    }
    .open-maths:hover { opacity: 0.88; }
    .drawer-backdrop { position: fixed; inset: 0; background: rgba(28,27,24,0.28); z-index: 40; }
    .drawer {
      position: fixed; top: 0; right: 0; height: 100vh; width: min(440px, 92vw);
      background: color-mix(in srgb, var(--color-paper) 60%, white);
      border-left: 1px solid var(--color-rule);
      box-shadow: -18px 0 50px -28px rgba(0,0,0,0.4);
      transform: translateX(100%); transition: transform 0.28s ease; z-index: 50;
      display: flex; flex-direction: column;
    }
    .drawer.open { transform: translateX(0); }
    .drawer-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.8rem 1rem; border-bottom: 1px solid var(--color-rule); background: var(--color-card);
    }
    .drawer-close { font-size: 1.3rem; line-height: 1; background: none; border: none; cursor: pointer; color: var(--color-ink-soft); }
    .drawer-body { padding: 1rem 1.2rem; overflow-y: auto; }
  </style>
</Layout>
